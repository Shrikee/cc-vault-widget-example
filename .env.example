# --- RPC (reads) -----------------------------------------------------------
# Ethereum mainnet RPC used by the ethers read provider (TVL, share value,
# balances, withdraw statuses). A public endpoint is used if this is unset, but
# set your own (Infura/Alchemy/etc.) for production reliability and rate limits.
VITE_RPC_URL=https://ethereum-rpc.publicnode.com

# --- WalletConnect (writes) -----------------------------------------------
# Project id from https://cloud.reown.com (WalletConnect). Optional: injected
# wallets (MetaMask, Rabby, ...) work without it; WalletConnect/mobile QR needs it.
VITE_WALLETCONNECT_PROJECT_ID=
